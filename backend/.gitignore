# ============================================================
#  EduVerse AI Backend — .gitignore
# ============================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (NEVER commit real secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Firebase service account key (if using a JSON file instead of env vars)
*serviceAccount*.json
*service-account*.json
firebase-adminsdk*.json
firebase-service-account.json

# Logs
logs/
*.log

# Build output
dist/
build/

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
